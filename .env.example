# BandChat Website Template Configuration
# Copy to .env and fill in values

# ── Site Identity (used by API endpoints) ─────────────────────
SITE_DOMAIN=your-domain.com
CONTACT_EMAIL=info@your-domain.com
BAND_NAME=Your Band Name

# ── BandChat API (for sync script and admin panel) ────────────
VITE_BANDCHAT_URL=http://localhost:3001
VITE_WORKSPACE_ID=your-workspace-id-here

# ── Sync Script Credentials (BandChat login) ──────────────────
SYNC_BANDCHAT_URL=http://localhost:3001
SYNC_EMAIL=your-bandchat-email
SYNC_PASSWORD=your-bandchat-password
SYNC_WORKSPACE_ID=your-workspace-id-here

# ── Anthropic API (for AI Agents panel, server-side only) ─────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Resend API (for contact form and song request emails) ─────
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=Your Band <noreply@your-domain.com>

# ── AI Agent Prompts (optional, overrides defaults) ───────────
# AGENT_AMP_PROMPT=Custom system prompt for the design agent
# AGENT_BUZZ_PROMPT=Custom system prompt for the social media agent
# AGENT_RIFF_PROMPT=Custom system prompt for the copywriting agent
